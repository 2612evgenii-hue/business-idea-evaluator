{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/2612evgenii-hue/business-idea-evaluator/evidence-package.schema.json",
  "title": "Expert Evidence Package (BRS input)",
  "description": "Merged input consumed by scripts/calculate_brs.py. Built by the orchestrator from 12 expert subagents (Phase 2) and 6 math subagents (Phase 3).",
  "type": "object",
  "required": ["idea_brief", "experts", "math"],
  "additionalProperties": true,
  "properties": {
    "idea_brief": {
      "type": "string",
      "minLength": 1,
      "description": "Confirmed one-paragraph idea summary (idea_summary)."
    },
    "confirmed_at": { "type": "string", "description": "ISO date the idea was confirmed." },
    "internet_available": {
      "type": "boolean",
      "description": "If false, market claims are downgraded to hypotheses and source quality is capped."
    },
    "failed_agents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of subagents that failed to return output."
    },
    "experts": {
      "type": "object",
      "description": "expert_agents — keys '01'..'12'.",
      "required": ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"],
      "additionalProperties": { "$ref": "#/definitions/expertOutput" },
      "propertyNames": { "pattern": "^(0[1-9]|1[0-2])$" }
    },
    "math": {
      "type": "object",
      "description": "math_agents — keys '13'..'18'.",
      "required": ["13", "14", "15", "16", "17", "18"],
      "additionalProperties": true,
      "propertyNames": { "pattern": "^(1[3-8])$" }
    }
  },
  "definitions": {
    "score10": { "type": "number", "minimum": 0, "maximum": 10 },
    "source": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "confirms": { "type": "string" },
        "freshness": { "type": "string" },
        "reliability": { "$ref": "#/definitions/score10" },
        "market_match": { "type": "string" }
      },
      "additionalProperties": true
    },
    "expertOutput": {
      "type": "object",
      "description": "Single expert subagent output.",
      "required": ["scores"],
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "findings": { "type": "array", "items": { "type": "string" } },
        "sources": { "type": "array", "items": { "$ref": "#/definitions/source" } },
        "hypotheses": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "scores": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/definitions/score10" }
        },
        "evidence_level": { "$ref": "#/definitions/score10" },
        "confidence": { "$ref": "#/definitions/score10" },
        "metrics": { "type": "object" },
        "math_params": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    },
    "final_brs_input": {
      "description": "Alias note: the root object itself IS the final_brs_input passed to calculate_brs.py.",
      "type": "object"
    }
  }
}
